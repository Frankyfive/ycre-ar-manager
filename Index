}

// ── SIDEBAR ───────────────────────────────────────────────────
function sidebar() {
  const views = [
    { id:'aging',    label:'AR Aging',  badge: null },
    { id:'agents',   label:'By Agent',  badge: S.data.agents.length },
    { id:'settings', label:'Settings',  badge: null },
