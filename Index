function buildPreview(t) {
  const subject = t.subject
    .replace(/\{\{invoiceNum\}\}/g,'123208').replace(/\{\{balance\}\}/g,'$356')
    .replace(/\{\{customerName\}\}/g,'Sasha Jam').replace(/\{\{dueDate\}\}/g,'3/1/2026');
  const body = t.body
    .replace(/\{\{customerName\}\}/g,'Sasha Jam').replace(/\{\{invoiceNum\}\}/g,'123208')
    .replace(/\{\{balance\}\}/g,'$356').replace(/\{\{dueDate\}\}/g,'3/1/2026')
    .replace(/\{\{dueDateLine\}\}/g,', which was due on 3/1/2026')
    .replace(/\{\{itemList\}\}/g,'  • Office Rent: March 2026 Office Rent');
  return `Subject: ${subject}\n\n${body}\n\n${t.signature}`;
}

function saveTemplateFromUI() {
  S.template = {
    subject:   document.getElementById('tpl_subject')?.value   || DEFAULT_TEMPLATE.subject,
    body:      document.getElementById('tpl_body')?.value      || DEFAULT_TEMPLATE.body,
    signature: document.getElementById('tpl_signature')?.value || DEFAULT_TEMPLATE.signature,
  };
  saveTemplate(S.template);
  const prev = document.getElementById('tpl_preview');
  if (prev) prev.textContent = buildPreview(S.template);
  const saved = document.getElementById('tpl_saved');
  if (saved) { saved.style.display='inline'; setTimeout(()=>saved.style.display='none',2000); }
}

function resetTemplate() {
  if (!confirm('Reset to default template?')) return;
  S.template = { ...DEFAULT_TEMPLATE };
  saveTemplate(S.template);
  refreshContent();
}

// ── EMAIL MODAL ───────────────────────────────────────────────
function openEmail(invoiceId) {
  const inv = S.data.invoices.find(i => i.invoiceId === invoiceId);
  if (!inv) return;
  const t = S.template;
  const itemList = inv.lineItems.map(li => `  • ${li.itemName}: ${li.description}`).join('\n') || '  (see invoice for details)';
  const dueDateLine = inv.dueDate ? `, which was due on ${inv.dueDate}` : '';
  const subject = t.subject
    .replace(/\{\{invoiceNum\}\}/g, inv.invoiceNum).replace(/\{\{balance\}\}/g, fmt$(inv.balance))
    .replace(/\{\{customerName\}\}/g, inv.customerName).replace(/\{\{dueDate\}\}/g, inv.dueDate||'');
  const body = t.body
    .replace(/\{\{customerName\}\}/g, inv.customerName).replace(/\{\{invoiceNum\}\}/g, inv.invoiceNum)
    .replace(/\{\{balance\}\}/g, fmt$(inv.balance)).replace(/\{\{dueDate\}\}/g, inv.dueDate||'')
    .replace(/\{\{dueDateLine\}\}/g, dueDateLine).replace(/\{\{itemList\}\}/g, itemList);
  document.getElementById('modalSub').textContent = `Invoice #${inv.invoiceNum} - ${inv.customerName}`;
  document.getElementById('emailTo').value      = inv.email || '';
  document.getElementById('emailSubject').value = subject;
  document.getElementById('emailBody').value    = body + '\n\n' + t.signature;
  updateMailto();
  document.getElementById('emailModal').style.display = 'flex';
}

function closeModal() { document.getElementById('emailModal').style.display = 'none'; }

function updateMailto() {
  const to  = document.getElementById('emailTo').value;
  const sub = encodeURIComponent(document.getElementById('emailSubject').value);
  const bod = encodeURIComponent(document.getElementById('emailBody').value);
  document.getElementById('sendBtn').href = `mailto:${to}?subject=${sub}&body=${bod}`;
}

function bindModal() {
  document.getElementById('emailModal')?.addEventListener('click', e => { if(e.target===e.currentTarget) closeModal(); });
  ['emailSubject','emailBody'].forEach(id => document.getElementById(id)?.addEventListener('input', updateMailto));
}

function copyEmailBody() {
  copyText(document.getElementById('emailBody')?.value || '');
}

// ── COPY HELPER ───────────────────────────────────────────────
function copyText(text) {
  navigator.clipboard.writeText(text).then(() => {
    const t = document.createElement('div');
    t.className = 'copy-toast'; t.textContent = '✓ Copied';
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 1800);
  });
}

// ── LIVE SEARCH ───────────────────────────────────────────────
function bindSearch() {
  const box = document.getElementById('searchBox');
  if (!box) return;
  if (box._bound) return;
  box._bound = true;
  box.addEventListener('input', (e) => {
    S.search = e.target.value;
    applySearch();
  });
}

function applySearch() {
  const q = (S.search || '').trim().toLowerCase();

  if (S.view === 'agents') {
    const rows = document.querySelectorAll('.agent-table tbody tr');
    let visible = 0;
    rows.forEach(r => {
      const blob = r.getAttribute('data-search') || '';
      const hit  = !q || blob.includes(q);
      r.classList.toggle('hit-hidden', !hit);
      if (hit) visible++;
    });
    updatePanelSub(visible, rows.length);
    return;
  }

  if (S.view === 'settings') return;

  // Aging view: hide/show customer group rows + their child sections
  const rows = document.querySelectorAll('.cust-group-row');
  let visible = 0;
  rows.forEach(r => {
    const blob = r.getAttribute('data-search') || '';
    const hit  = !q || blob.includes(q);
    r.classList.toggle('hit-hidden', !hit);
    // Also hide/show the inv-item-section right after
    let next = r.nextElementSibling;
    if (next && next.classList.contains('inv-item-section')) {
      next.classList.toggle('hit-hidden', !hit);
    }
    if (hit) visible++;
  });
  updatePanelSub(visible, rows.length);
}

function updatePanelSub(visible, total) {
  const sub = document.getElementById('panelSub');
  if (!sub) return;
  if (S.view === 'agents') {
    sub.textContent = visible === total
      ? 'Click any row to filter invoices'
      : `${visible} of ${total} groups match`;
  } else {
    sub.textContent = visible === total
      ? `${total} open invoices`
      : `${visible} of ${total} customers match`;
  }
}

// ── HELPERS ───────────────────────────────────────────────────
function getBucket(days) {
  if (days === null || days === undefined || days <= 0) return 'future';
  if (days <= 30) return '1-30';
  if (days <= 60) return '31-60';
  if (days <= 90) return '61-90';
  return '91+';
}

function daysBadge(days) {
  if (days === null || days === undefined) return '<span class="days-badge days-neg">-</span>';
  if (days > 90) return `<span class="days-badge days-91">${days}d</span>`;
  if (days > 60) return `<span class="days-badge days-61">${days}d</span>`;
  if (days > 30) return `<span class="days-badge days-31">${days}d</span>`;
  if (days > 0)  return `<span class="days-badge days-0">${days}d</span>`;
  return `<span class="days-badge days-neg">${Math.abs(days)}d left</span>`;
}

function fmt$(n) {
  return new Intl.NumberFormat('en-US',{style:'currency',currency:'USD',maximumFractionDigits:0}).format(n||0);
}

function esc(s) {
  return String(s||'')
    .replace(/&/g,'&amp;')
    .replace(/'/g,"\\'")
    .replace(/"/g,'&quot;');
}

function filteredInvoices() {
  let list = S.data.invoices;
  if (S.itemFilter) list = list.filter(i => i.itemNames.includes(S.itemFilter));
  if (S.agentFilter) {
    if (S.agentFilter === '__NON_AGENT__') {
      list = list.filter(i => !i.agentId);
    } else {
      list = list.filter(i => i.agentName === S.agentFilter);
    }
  }
  return list;
}

// ── EVENT HANDLERS ────────────────────────────────────────────
function toggleBucket(key) {
  S.expandedBuckets.has(key) ? S.expandedBuckets.delete(key) : S.expandedBuckets.add(key);
  refreshContent();
}
function toggleCustGroup(key) {
  S.expandedCustomers.has(key) ? S.expandedCustomers.delete(key) : S.expandedCustomers.add(key);
  refreshContent();
}
function toggleInvoice(id) {
  S.expandedInvoices.has(id) ? S.expandedInvoices.delete(id) : S.expandedInvoices.add(id);
  refreshContent();
}
function toggleItemFilter(name) { S.itemFilter = S.itemFilter === name ? null : name; rerender(); }
function filterByAgent(name) { S.agentFilter = name; S.view = 'aging'; rerender(); }
function drillAgent(name, isUnassigned) {
  S.agentFilter = isUnassigned ? '__NON_AGENT__' : name;
  S.view = 'aging';
  S.expandedBuckets = new Set(['1-30','31-60','61-90','91+','future']);
  rerender();
}
function sortAgent(col) {
  S.sortAgent.dir = S.sortAgent.col === col ? S.sortAgent.dir * -1 : -1;
  S.sortAgent.col = col;
  refreshContent();
}

// ── EXPAND / COLLAPSE ALL ─────────────────────────────────────
function toggleExpandAll() {
  const invoices = filteredInvoices();
  const bucketed = {};
  BUCKETS.forEach(b => { bucketed[b.key] = {}; });
  invoices.forEach(inv => {
    const b = getBucket(inv.daysOut);
    if (!bucketed[b]) return;
    const cName = inv.customerName || 'Unknown';
    if (!bucketed[b][cName]) bucketed[b][cName] = [];
    bucketed[b][cName].push(inv);
  });

  const activeBucketKeys = BUCKETS.map(b => b.key).filter(k => {
    return Object.entries(bucketed[k]).flatMap(([,invs]) => invs).length > 0;
  });
  const allExpanded = activeBucketKeys.length > 0 && activeBucketKeys.every(k => S.expandedBuckets.has(k));

  if (allExpanded) {
    // Collapse all
    S.expandedBuckets.clear();
    S.expandedCustomers.clear();
    S.expandedInvoices.clear();
  } else {
    // Expand all buckets (customer groups stay collapsed for readability)
    activeBucketKeys.forEach(k => S.expandedBuckets.add(k));
  }
  refreshContent();
}
