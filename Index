// ── CONTENT ROUTER ────────────────────────────────────────────
function content() {
  if (S.view === 'agents')   return agentView();
  if (S.view === 'settings') return settingsView();
  return agingView();
}

// ══════════════════════════════════════════════════════════════
//  AGING VIEW  (CUSTOMER → ITEMS hierarchy)
// ══════════════════════════════════════════════════════════════
function agingView() {
  const { summary } = S.data;
  const statCards = [
    { label:'Total AR',   value: fmt$(summary.totalAR),   sub: `${summary.totalInvoices} open invoices`, cls:'accent' },
    { label:'91+ Days',   value: fmt$(summary.bucket91),  sub: `${summary.count91} invoices`,            cls:'red'    },
    { label:'61-90 Days', value: fmt$(summary.bucket61),  sub: `${summary.count61} invoices`,            cls:'orange' },
    { label:'31-60 Days', value: fmt$(summary.bucket31),  sub: `${summary.count31} invoices`,            cls:'yellow' },
  ];
  const statsHtml = statCards.map(c => `
    <div class="stat-card ${c.cls}">
      <div class="stat-label">${c.label}</div>
      <div class="stat-value">${c.value}</div>
      <div class="stat-sub">${c.sub}</div>
    </div>`).join('');

  const invoices = filteredInvoices();

  // Group: bucket → customerName → invoices
  const bucketed = {};
  BUCKETS.forEach(b => { bucketed[b.key] = {}; });
  invoices.forEach(inv => {
    const b = getBucket(inv.daysOut);
    if (!bucketed[b]) return;
    const cName = inv.customerName || 'Unknown';
    if (!bucketed[b][cName]) bucketed[b][cName] = [];
    bucketed[b][cName].push(inv);
  });

  // Determine expand/collapse all state
  const allBucketKeys = BUCKETS.map(b => b.key).filter(k => {
    const entries = Object.entries(bucketed[k]);
    return entries.flatMap(([,invs]) => invs).length > 0;
  });
  const allExpanded = allBucketKeys.length > 0 && allBucketKeys.every(k => S.expandedBuckets.has(k));

  const bucketsHtml = BUCKETS.map(b => {
    const custEntries = Object.entries(bucketed[b.key]);
    const bucketTotal = custEntries.flatMap(([,invs]) => invs).reduce((s,i) => s+i.balance, 0);
    const bucketCount = custEntries.flatMap(([,invs]) => invs).length;
    if (bucketCount === 0) return '';
    const isOpen = S.expandedBuckets.has(b.key);

    const maxCustTotal = Math.max(...custEntries.map(([,invs]) => invs.reduce((s,i)=>s+i.balance,0)), 1);

    const custsHtml = !isOpen ? '' : `
      <div class="slide-in">
        <div class="table-head-cust">
          <div></div>
          <div class="col-head">Customer</div>
          <div class="col-head">Balance</div>
          <div class="col-head">Invoices</div>
          <div class="col-head">Oldest</div>
          <div class="col-head"></div>
        </div>
        ${custEntries.sort((a,b2) =>
          b2[1].reduce((s,i)=>s+i.balance,0) - a[1].reduce((s,i)=>s+i.balance,0)
        ).map(([cName, invs]) => {
          const custTotal = invs.reduce((s,i) => s+i.balance, 0);
          const custKey = b.key + '||' + cName;
          const custOpen = S.expandedCustomers.has(custKey);
          const oldestDays = Math.max(...invs.map(i => i.daysOut || 0));
          const isAgent = invs.some(i => !!i.agentId);
          const searchBlob = [
            cName, ...invs.flatMap(i => [i.invoiceNum, i.email, i.agentName, i.officeName, ...(i.itemNames||[])])
          ].filter(Boolean).join(' ').toLowerCase();

          // Invoice rows inside customer
          const invHtml = !custOpen ? '' : `
            <div class="inv-item-section slide-in">
              ${invs.sort((a,bv) => bv.balance - a.balance).map(inv => {
                const invOpen = S.expandedInvoices.has(inv.invoiceId);
                const itemLabel = inv.itemNames.join(', ') || 'No item';
                return `
                  <div class="inv-item-row ${invOpen?'open':''}" onclick="toggleInvoice('${inv.invoiceId}')">
                    <div class="inv-chevron">▶</div>
                    <div>
                      <span style="font-weight:600;font-size:12px">${itemLabel}</span>
                      <div style="font-size:11px;color:var(--text3);margin-top:1px">#${inv.invoiceNum}</div>
                    </div>
                    <div style="font-size:11px;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${inv.lineItems.map(l=>l.description).join(', ')}">${inv.lineItems.map(l=>l.description).join(', ') || '-'}</div>
                    <div class="money ${inv.balance>=5000?'red':inv.balance>=1000?'orange':'normal'}">${fmt$(inv.balance)}</div>
                    <div>${daysBadge(inv.daysOut)}</div>
                    <div style="font-size:12px;color:var(--text2)">${inv.dueDate}</div>
                    <div style="font-size:12px;color:var(--text2)">${inv.agentName||'-'}</div>
                    <div>
                      <button class="btn btn-outline" style="padding:4px 9px;font-size:11px"
                        onclick="event.stopPropagation();openEmail('${inv.invoiceId}')">✉</button>
                    </div>
                  </div>
                  ${invOpen ? invoiceDetail(inv) : ''}`;
              }).join('')}
            </div>`;

          return `
            <div class="cust-group-row ${custOpen?'open':''}" data-search="${esc(searchBlob)}" onclick="toggleCustGroup('${esc(custKey)}')">
              <div class="cust-group-chevron">▶</div>
              <div>
                <span class="cust-group-name">${cName}</span>
                ${isAgent
                  ? '<span class="cust-tag">Agent</span>'
                  : '<span class="cust-tag non-agent">Non-Agent</span>'}
                <div class="cust-group-email">${invs[0]?.email || ''}</div>
              </div>
              <div class="money ${custTotal>=5000?'red':custTotal>=1000?'orange':'normal'}" style="font-size:13px">${fmt$(custTotal)}</div>
              <div style="font-size:12px;color:var(--text3)">${invs.length} inv${invs.length>1?'s':''}</div>
              <div>${daysBadge(oldestDays)}</div>
              <div></div>
            </div>
            ${invHtml}`;
        }).join('')}
      </div>`;

    return `
      <div>
        <div class="bucket-header ${isOpen?'open':''}" onclick="toggleBucket('${b.key}')">
          <div class="bucket-chevron">▶</div>
          <div class="bucket-pill ${b.pill}">${b.label}</div>
          <div class="bucket-spacer"></div>
          <div class="bucket-count">${bucketCount} invoice${bucketCount>1?'s':''}</div>
          <div style="width:20px"></div>
          <div class="bucket-total" style="color:var(--${b.totalClass})">${fmt$(bucketTotal)}</div>
        </div>
        ${custsHtml}
      </div>`;
  }).join('');

  return `
    <div class="stat-row fade-in">${statsHtml}</div>
    <div class="panel fade-in">
      <div class="panel-header">
        <div class="panel-title">AR Aging Detail</div>
        <div class="panel-sub" id="panelSub">${invoices.length} open invoices</div>
        <div class="panel-spacer"></div>
        <button class="btn btn-outline" style="font-size:11px;padding:5px 12px" onclick="toggleExpandAll()">
          ${allExpanded ? '⊟ Collapse All' : '⊞ Expand All'}
        </button>
        <input class="search-box" id="searchBox" placeholder="Search customer, invoice, agent..." value="${esc(S.search)}" autocomplete="off">
      </div>
      ${bucketsHtml}
    </div>`;
}

// ── INVOICE DETAIL ────────────────────────────────────────────
function invoiceDetail(inv) {
  const liRows = inv.lineItems.map(li => `
    <tr>
      <td style="font-weight:600">${li.itemName}</td>
      <td style="color:var(--text2)">${li.description}</td>
      <td class="money">${fmt$(li.unitPrice)}</td>
      <td style="color:var(--text3)">${li.className||'-'}</td>
    </tr>`).join('') || `<tr><td colspan="4" style="color:var(--text3)">No line items</td></tr>`;

  const pending = inv.agentId ? (S.data.pendingByAgent?.[inv.agentId] || []) : [];
  const grouped = {};
  pending.forEach(p => {
    const key = p.wsId || p.address || 'unknown';
    if (!grouped[key]) grouped[key] = { wsId: p.wsId, address: p.address, closeDate: p.closeDate, agentName: p.agentName, items: [] };
    grouped[key].items.push(p);
  });

  const uniqueTxCount = Object.keys(grouped).length;
  const pendingHtml = uniqueTxCount === 0 ? '' : `
    <div class="pending-section">
      <div class="pending-title">⏳ Pending Transactions - ${inv.agentName} <span style="color:var(--text3);font-weight:500;margin-left:8px">${uniqueTxCount} transaction${uniqueTxCount===1?'':'s'} · ${pending.length} line item${pending.length===1?'':'s'}</span></div>
      ${Object.values(grouped).map(tx => {
        const totalAmt = tx.items.reduce((s,i) => s+i.amount, 0);
        return `
        <div style="margin-bottom:10px;border:1px solid var(--border);border-radius:6px;overflow:hidden">
          <div style="display:flex;align-items:center;gap:12px;padding:8px 12px;background:var(--bg);border-bottom:1px solid var(--border);flex-wrap:wrap">
            <div style="font-size:11px;color:var(--text3);white-space:nowrap">${tx.closeDate}</div>
            <div style="font-weight:600;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:5px;flex:1"
              onclick="copyText('${esc(tx.address)}')" title="Click to copy address">
              ${tx.address} <span style="font-size:10px;color:var(--text3)">⧉</span>
            </div>
            <div style="font-size:11px;color:var(--text2)">${tx.agentName}</div>
            ${tx.wsId ? `<div style="font-family:var(--mono);font-size:11px;cursor:pointer;background:var(--accent-lt);color:var(--accent);padding:2px 8px;border-radius:4px;display:flex;align-items:center;gap:4px"
              onclick="copyText('${esc(tx.wsId)}')" title="Click to copy WS ID">
              WS#${tx.wsId} <span style="font-size:10px">⧉</span>
            </div>` : ''}
            <div class="money" style="color:${totalAmt<0?'var(--red)':'var(--green)'};">${fmt$(totalAmt)}</div>
          </div>
          ${tx.items.map(item => `
            <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 12px;border-bottom:1px solid var(--border);gap:12px">
              <span style="background:var(--orange-lt);color:var(--orange);font-size:10px;font-weight:700;padding:1px 7px;border-radius:4px">${item.itemName}</span>
              <span class="money" style="color:${item.amount<0?'var(--red)':'var(--green)'};font-size:12px">${fmt$(item.amount)}</span>
            </div>`).join('')}
        </div>`;
      }).join('')}
    </div>`;

  const qboInvUrl  = `https://app.qbo.intuit.com/app/invoice?txnId=${inv.invoiceId}`;
  const qboCustUrl = `https://app.qbo.intuit.com/app/customerdetail?nameId=${inv.customerId}`;
  const qboLink = (url, label) => `<a href="${url}" target="_blank" style="color:var(--accent);text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:3px">${label} <span style="font-size:10px;opacity:0.7">↗</span></a>`;

  const copyableEmail = inv.email
    ? `<span style="cursor:pointer;display:inline-flex;align-items:center;gap:5px" onclick="copyText('${esc(inv.email)}')" title="Click to copy">
        ${inv.email} <span style="font-size:10px;color:var(--text3)">⧉</span>
       </span>`
    : '-';

  return `
    <div class="invoice-detail slide-in">
      <div class="detail-grid">
        <div>
          <div class="detail-section-title">Invoice</div>
          <div class="detail-row"><span class="detail-key">Invoice #</span><span class="detail-val">${qboLink(qboInvUrl, inv.invoiceNum)}</span></div>
          <div class="detail-row"><span class="detail-key">Due Date</span><span class="detail-val">${inv.dueDate}</span></div>
          <div class="detail-row"><span class="detail-key">Created</span><span class="detail-val">${inv.createdAt}</span></div>
          <div class="detail-row"><span class="detail-key">Balance Due</span><span class="detail-val" style="color:var(--red)">${fmt$(inv.balance)}</span></div>
          <div class="detail-row"><span class="detail-key">QB Email Status</span><span class="detail-val">${inv.emailStatus||'-'}</span></div>
        </div>
        <div>
          <div class="detail-section-title">Customer</div>
          <div class="detail-row"><span class="detail-key">Name</span><span class="detail-val">${qboLink(qboCustUrl, inv.customerName)}</span></div>
          <div class="detail-row"><span class="detail-key">Email</span><span class="detail-val" style="font-size:11px">${copyableEmail}</span></div>
          <div class="detail-row"><span class="detail-key">Total Customer Balance</span><span class="detail-val">${fmt$(inv.custBalance)}</span></div>
          <div class="detail-row"><span class="detail-key">Agent</span><span class="detail-val">${inv.agentName||'<span style="color:var(--text3)">Non-Agent</span>'}</span></div>
          <div class="detail-row"><span class="detail-key">Office</span><span class="detail-val" style="font-size:11px">${inv.officeName||'-'}</span></div>
        </div>
        <div>
          <div class="detail-section-title">AR Notes</div>
          ${inv.custNotes
            ? `<div class="notes-area">${inv.custNotes}</div>`
