        <tbody>${liRows}</tbody>
      </table>
      ${pendingHtml}
      <div class="action-bar">
        <button class="btn btn-primary" onclick="openEmail('${inv.invoiceId}')">✉ Send Reminder</button>
        ${inv.qboUrl ? `<a class="btn btn-green" href="${inv.qboUrl}" target="_blank">↗ Open in QuickBooks</a>` : ''}
        ${inv.agentName ? `<button class="btn btn-outline" onclick="filterByAgent('${esc(inv.agentName)}')">Filter by Agent</button>` : ''}
      </div>
    </div>`;
}

// ── AGENT VIEW ────────────────────────────────────────────────
function agentView() {
  const agents = S.data.agents;
  const sorted = [...agents].sort((a,b) => {
    if (!a.agentId && b.agentId) return 1;
    if (a.agentId && !b.agentId) return -1;
    let av = a[S.sortAgent.col], bv = b[S.sortAgent.col];
    return (av < bv ? 1 : av > bv ? -1 : 0) * S.sortAgent.dir;
  });
  const maxAR = Math.max(...agents.map(a => a.totalAR), 1);

  const realAgents = agents.filter(a => a.agentId);
  const summary = {
    totalAR:    agents.reduce((s,a) => s+a.totalAR, 0),
    agentAR:    realAgents.reduce((s,a) => s+a.totalAR, 0),
    nonAgentAR: agents.filter(a => !a.agentId).reduce((s,a) => s+a.totalAR, 0),
    agentCount: realAgents.length,
    avgAR:      realAgents.length ? realAgents.reduce((s,a)=>s+a.totalAR,0)/realAgents.length : 0
  };

  const th = (col, label) => {
    const active = S.sortAgent.col === col;
    return `<th onclick="sortAgent('${col}')" style="${active?'color:var(--accent)':''}">${label} ${active?(S.sortAgent.dir===-1?'↓':'↑'):'↕'}</th>`;
  };
  const rows = sorted.map(a => {
    const pct = (a.totalAR / maxAR * 100).toFixed(1);
    const color = a.totalAR > 10000 ? 'var(--red)' : a.totalAR > 5000 ? 'var(--orange)' : 'var(--green)';
    const isUnassigned = !a.agentId;
    const pc = typeof a.pendingCount === 'number' ? a.pendingCount : (a.pending ? a.pending.length : 0);
    const pendingBadge = pc > 0
      ? `<span style="background:var(--orange-lt);color:var(--orange);font-size:11px;font-weight:700;padding:2px 8px;border-radius:4px">${pc} pending</span>`
      : '<span style="color:var(--text3)">-</span>';
    const searchBlob = [a.agentName, a.officeName].filter(Boolean).join(' ').toLowerCase();

    return `
      <tr class="${isUnassigned?'unassigned':''}" data-search="${esc(searchBlob)}" onclick="drillAgent('${esc(a.agentName)}', ${isUnassigned})">
        <td>
          <div style="font-weight:600">${a.agentName}</div>
          <div style="font-size:11px;color:var(--text3)">${a.officeName || (isUnassigned ? 'Customers not linked to an agent' : '')}</div>
        </td>
        <td>
          <div class="money" style="color:${color}">${fmt$(a.totalAR)}</div>
          <div class="agent-bar"><div class="agent-bar-fill" style="width:${pct}%;background:${color}"></div></div>
        </td>
        <td class="money">${a.invoiceCount}</td>
        <td class="money">${a.customerCount}</td>
        <td>${isUnassigned ? '<span style="color:var(--text3)">-</span>' : pendingBadge}</td>
        <td><button class="btn btn-outline" style="font-size:11px;padding:5px 10px" onclick="event.stopPropagation();drillAgent('${esc(a.agentName)}', ${isUnassigned})">View Invoices →</button></td>
      </tr>`;
  }).join('');

  return `
    <div class="stat-row fade-in" style="grid-template-columns:repeat(4,1fr)">
      <div class="stat-card accent"><div class="stat-label">Total AR</div><div class="stat-value">${fmt$(summary.totalAR)}</div><div class="stat-sub">across all groups</div></div>
      <div class="stat-card green"><div class="stat-label">Agent AR</div><div class="stat-value">${fmt$(summary.agentAR)}</div><div class="stat-sub">${summary.agentCount} agents</div></div>
      <div class="stat-card orange"><div class="stat-label">Non-Agent AR</div><div class="stat-value">${fmt$(summary.nonAgentAR)}</div><div class="stat-sub">B2B / unassigned</div></div>
      <div class="stat-card red"><div class="stat-label">Avg AR / Agent</div><div class="stat-value">${fmt$(summary.avgAR)}</div><div class="stat-sub">per agent average</div></div>
    </div>
    <div class="panel fade-in">
      <div class="panel-header">
        <div class="panel-title">Agent AR Summary</div>
        <div class="panel-sub" id="panelSub">Click any row to filter invoices</div>
        <div class="panel-spacer"></div>
        <input class="search-box" id="searchBox" placeholder="Search agent, office..." value="${esc(S.search)}" autocomplete="off">
      </div>
      <table class="agent-table">
        <thead><tr>${th('agentName','Agent')}${th('totalAR','AR Balance')}${th('invoiceCount','Invoices')}${th('customerCount','Customers')}<th>Pending</th><th></th></tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
}

